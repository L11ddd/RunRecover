# ──────────────────────────────────────────────
# RunRecover 后端环境变量配置示例
# 使用方法：复制本文件为 .env，填入真实值，然后在启动后端前 source 或手动 set
# 注意：.env 文件包含密钥，不要提交到 git！
# ──────────────────────────────────────────────

# 数据库路径（默认 SQLite，一般不需要改）
RUNRECOVER_DATABASE_URL=sqlite:///./data/runrecover.db

# 运行环境：development 或 production。当前主要用于部署文档和配置区分。
RUNRECOVER_ENV=development

# 允许访问后端 API 的前端域名，多个域名用英文逗号分隔。
# 本地开发默认允许 Vite 的 5173 端口；生产部署时改成你的 HTTPS Web/PWA 域名。
RUNRECOVER_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# 推荐引擎选择：
#   template   → 纯规则模板，无需 API key，适合本地演示（默认）
#   deepseek   → 调用 DeepSeek 大模型，需要填写下方 API key
#   openai     → 调用 OpenAI 官方 API
#   anthropic  → 调用 Claude/Anthropic API（支持 Claude key）
RUNRECOVER_LLM_PROVIDER=deepseek

# LLM API key
# DeepSeek: https://platform.deepseek.com/api_keys
# OpenAI:  https://platform.openai.com/account/api-keys
# Claude:  https://console.anthropic.com/account/api-keys
RUNRECOVER_LLM_API_KEY=sk-your-llm-key-here

# API 地址，由 provider 自动选取。默认值：
#   deepseek  -> https://api.deepseek.com
#   openai    -> https://api.openai.com/v1
#   anthropic -> https://api.anthropic.com/v1
RUNRECOVER_LLM_BASE_URL=https://api.deepseek.com

# 模型名称
# deepseek:   deepseek-chat 或 deepseek-reasoner
# openai:     gpt-3.5-turbo 或 gpt-4
# anthropic:  claude-sonnet-4-5 或其他 /v1/models 返回的模型 ID
RUNRECOVER_LLM_MODEL=deepseek-chat

# API 调用超时秒数（网络慢时适当调大）
RUNRECOVER_LLM_TIMEOUT=20
